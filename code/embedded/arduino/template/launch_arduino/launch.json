{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Arduino UNO (simavr)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/miniRTOS.ino.elf",
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/avr-gdb",
      "miDebuggerServerAddress": "localhost:1234",
      "stopAtEntry": true,
      "setupCommands": [
        {
          "description": "Enable pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}


